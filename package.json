{
  "name": "ecommerce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:frontend": "next dev",
    "dev:backend": "nodemon src/server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",

    "build": "next build",
    "start": "next start",

    "build:backend": "tsc src/server.ts --outDir dist --lib dom,esnext --module commonjs --target es6 --moduleResolution node --esModuleInterop true --skipLibCheck true --noEmit false",
    "start:backend": "node dist/server.js",

    "db:init": "ts-node src/db/init.ts",
    "lint": "eslint"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5"
  }
}
